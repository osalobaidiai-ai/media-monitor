APP_NAME=Saudi Media Monitor
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-this-to-a-strong-secret-key

DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/media_monitor
DATABASE_URL_SYNC=postgresql://postgres:password@db:5432/media_monitor
REDIS_URL=redis://redis:6379

RSS_FETCH_INTERVAL=300
MAX_ARTICLES_PER_SOURCE=50
CRISIS_THRESHOLD=0.75

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:80"]
